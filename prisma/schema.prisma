generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Job {
  id           String     @id @default(cuid())
  slug         String     @unique
  title        String
  type         JobType
  location     String
  schedule     String
  description  String     @db.Text
  requirements String[]
  applyUrl     String
  published    Boolean    @default(false)
  publishedAt  DateTime?
  archivedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  updatedById  String?
  branchSlug   BranchSlug?

  @@index([published, archivedAt])
}

enum JobType {
  WAREHOUSE
  DELIVERY
  SALES
  ADMIN
}

enum BranchSlug {
  SAN_DIEGO
  LOS_ANGELES
  FRESNO
  SAN_JOSE
}

model Application {
  id             String     @id @default(cuid())
  jobId          String?
  jobSlug        String?
  jobTitle       String?
  firstName      String
  lastName       String
  email          String
  phone          String
  experience     String     @db.Text
  resumeUrl      String?
  resumeFilename String?
  resumeSize     Int?
  resumeMimeType String?
  status         AppStatus  @default(NEW)
  notes          String?    @db.Text
  createdAt      DateTime   @default(now())
  branchSlug     BranchSlug?

  @@index([createdAt])
  @@index([jobId])
  @@index([status])
  @@index([branchSlug])
}

enum AppStatus {
  NEW
  REVIEWED
  CONTACTED
  ARCHIVED
}

model PartnerApplication {
  id            String              @id @default(cuid())
  interestType  PartnerInterestType
  firstName     String
  lastName      String
  email         String
  businessName  String
  cellPhone     String
  businessPhone String?
  address       String
  city          String
  state         String
  zipCode       String
  howDidYouFind String
  status        AppStatus           @default(NEW)
  notes         String?             @db.Text
  createdAt     DateTime            @default(now())

  // Product catalog upload (vendor applications only)
  productCatalogUrl      String?
  productCatalogFilename String?
  productCatalogSize     Int?
  productCatalogMimeType String?

  // Optional credit-application fields (set when the applicant opts to also
  // request net 30 credit terms on the same submission).
  businessLegalName          String?
  dba                        String?
  ein                        String?
  yearsInBusiness            Int?
  businessType               String?
  estimatedMonthlyPurchases  String?
  bankName                   String?
  bankAccountLast4           String?
  tradeReference1Name        String?
  tradeReference1Phone       String?
  tradeReference2Name        String?
  tradeReference2Phone       String?
  signerName                 String?
  signerTitle                String?
  creditAgreedAt             DateTime?

  @@index([createdAt])
  @@index([status])
}

enum PartnerInterestType {
  BUYER
  VENDOR
}
