{
  "name": "lnc-food",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/routes.test.mjs",
    "test:full": "pnpm build && pnpm test",
    "generate:images": "tsx scripts/generate-images.ts",
    "regenerate:warehouse": "tsx scripts/regenerate-warehouse-images.ts",
    "postinstall": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio"
  },
  "prisma": {
    "seed": "dotenv -e .env.local -- tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next": "14.2.15",
    "next-auth": "5.0.0-beta.31",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@google/genai": "^1.50.1",
    "@tailwindcss/postcss": "4.1.12",
    "@types/node": "20.12.12",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "tailwindcss": "4.1.12",
    "tsx": "^4.21.0",
    "typescript": "5.4.5"
  }
}
